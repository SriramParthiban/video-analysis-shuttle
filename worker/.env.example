# Copy this file to  worker/.env  and fill in real values.
# NEVER commit the real .env (it is in .gitignore).

# From Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service role key: Project Settings -> API -> service_role (SECRET, server-only).
# This bypasses RLS, so it must ONLY ever live here on your machine — never in the app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# From https://console.anthropic.com/  (used to turn metrics into a coaching report)
ANTHROPIC_API_KEY=your-anthropic-key-here

# How often the worker checks for new videos (seconds)
POLL_INTERVAL_SECONDS=5
