# Copy to  mobile/.env  and fill in real values, then restart `npx expo start`.
#
# EXPO_PUBLIC_* variables are embedded into the app bundle. That is FINE here:
# the anon/publishable key is designed to be public and is protected by RLS.
# NEVER put the service_role key in this file — that one lives only in worker/.env.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here
